# ─────────────────────────────────────────────────────────────────────────────
# Health Management System — Environment Variables Template
# Copy this file to backend/.env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# When running via Docker Compose, use the service name "mongodb" as the host.
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme_strong_password
MONGO_URI=mongodb://admin:changeme_strong_password@mongodb:27017/healthdb?authSource=admin

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme_very_long_random_secret_at_least_32_chars
JWT_EXPIRE=7d

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ── Cloudinary (if used for image uploads) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
CLIENT_URL=http://localhost
